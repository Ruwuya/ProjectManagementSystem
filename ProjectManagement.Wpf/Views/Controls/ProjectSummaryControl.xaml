<UserControl x:Class="ProjectManagement.Wpf.Views.Controls.ProjectSummaryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top -->
        <Border Style="{StaticResource ShellPanelBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding ProjectName}"
                               Style="{StaticResource SectionTitleTextStyle}"/>
                    <TextBlock Text="{Binding CreatedBy}"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Style="{StaticResource OngoingStatusBadgeStyle}"
                        VerticalAlignment="Center"
                        Padding="12,6">
                    <TextBlock Text="{Binding Status}"/>
                </Border>
            </Grid>
        </Border>

        <!-- Summary -->
        <Grid Grid.Row="1" Margin="0,15,0,0">
            <UniformGrid Columns="3">
                <Border Style="{StaticResource ShellPanelBorderStyle}" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Sessions" Style="{StaticResource MutedTextStyle}"/>
                        <TextBlock Text="{Binding SessionsCount}" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ShellPanelBorderStyle}" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Notes" Style="{StaticResource MutedTextStyle}"/>
                        <TextBlock Text="{Binding NotesCount}" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ShellPanelBorderStyle}" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Materials" Style="{StaticResource MutedTextStyle}"/>
                        <TextBlock Text="{Binding MaterialsCount}" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>
    </Grid>
</UserControl>