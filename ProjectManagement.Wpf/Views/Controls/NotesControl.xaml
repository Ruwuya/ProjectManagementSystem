<UserControl x:Class="ProjectManagement.Wpf.Views.Controls.NotesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Style="{StaticResource ShellPanelBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding ProjectName}"
                               Style="{StaticResource SectionTitleTextStyle}"/>
                    <TextBlock Text="{Binding DateText}"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Notes list -->
        <Border Grid.Row="1"
                Style="{StaticResource ShellPanelBorderStyle}"
                Margin="0,15,0,15">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Notes History"
                           Style="{StaticResource SectionTitleTextStyle}"
                           Margin="0,0,0,10"/>

                <Grid Grid.Row="1">
                    <TextBlock Text="No notes for this project yet"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Notes.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ListBox ItemsSource="{Binding Notes}"
                             Background="{StaticResource MekBlackBrush}"
                             Foreground="{StaticResource MekTextBrush}"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ShellPanelBorderStyle}" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock>
                                            <Run Text="{Binding Username}"/>
                                            <Run Text=" • "/>
                                            <Run Text="{Binding Time}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Content}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Border>

        <!-- Input -->
        <Border Grid.Row="2"
                Style="{StaticResource ShellPanelBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Style="{StaticResource MekTextBoxStyle}"
                         Height="70"
                         Margin="0,0,10,0"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding NewNoteText, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Grid.Column="1"
                        Content="Send"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="110"
                        Height="40"
                        VerticalAlignment="Bottom"
                        Command="{Binding SendNoteCommand}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>