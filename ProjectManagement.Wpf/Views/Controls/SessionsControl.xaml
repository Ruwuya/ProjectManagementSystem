<UserControl x:Class="ProjectManagement.Wpf.Views.Controls.SessionsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Style="{StaticResource ShellPanelBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding ProjectName}"
                               Style="{StaticResource SectionTitleTextStyle}"/>
                    <TextBlock Text="{Binding DisplayDate}"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sessions -->
        <Border Grid.Row="1"
                Style="{StaticResource ShellPanelBorderStyle}"
                Margin="0,15,0,15">
            <DataGrid ItemsSource="{Binding Sessions}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderBrush="{StaticResource MekBorderBrush}"
                      BorderThickness="1"
                      Background="{StaticResource MekPanelBrush}"
                      Foreground="{StaticResource MekTextBrush}"
                      RowBackground="{StaticResource MekBlackBrush}"
                      AlternatingRowBackground="{StaticResource MekPanelBrush}"
                      HorizontalGridLinesBrush="{StaticResource MekBorderBrush}"
                      VerticalGridLinesBrush="{StaticResource MekBorderBrush}"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">

                <!-- Column Headers -->
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{StaticResource MekYellowBrush}"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="BorderBrush" Value="{StaticResource MekBorderBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <!-- Rows -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{StaticResource MekTextBrush}"/>
                        <Setter Property="Background" Value="{StaticResource MekBlackBrush}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource MekBorderBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="MinHeight" Value="34"/>
                        <Style.Triggers>
                            <Trigger Property="AlternationIndex" Value="1">
                                <Setter Property="Background" Value="{StaticResource MekPanelBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource MekYellowDarkBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource MekTextBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <!-- Cells -->
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="{StaticResource MekTextBrush}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="{StaticResource MekBorderBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="TextBlock.TextWrapping" Value="Wrap"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{StaticResource MekTextBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Username"
                                        Binding="{Binding Username}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Check In"
                                        Binding="{Binding CheckInText}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Check Out"
                                        Binding="{Binding CheckOutText}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Notes"
                                        Binding="{Binding Notes}"
                                        Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Bottom -->
        <Border Grid.Row="2"
                Style="{StaticResource ShellPanelBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="&lt;="
                            Style="{StaticResource BaseButtonStyle}"
                            Width="80"
                            Margin="0,0,5,0"
                            Command="{Binding PreviousDayCommand}"/>

                    <Button Content="Today"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="120"
                            Margin="5,0"
                            Command="{Binding TodayCommand}"/>

                    <Button Content="=&gt;"
                            Style="{StaticResource BaseButtonStyle}"
                            Width="80"
                            Margin="5,0,0,0"
                            Command="{Binding NextDayCommand}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Check Out"
                            Style="{StaticResource DangerButtonStyle}"
                            Width="120"
                            Margin="0,0,10,0"
                            Command="{Binding CheckOutCommand}"
                            IsEnabled="{Binding CanSessionActions}"/>

                    <Button Content="Check In"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="120"
                            Command="{Binding CheckInCommand}"
                            IsEnabled="{Binding CanSessionActions}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>