<Application x:Class="ProjectManagement.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ProjectManagement.Wpf.ViewModels"
             xmlns:views="clr-namespace:ProjectManagement.Wpf.Views.Controls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/MekTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type vm:ProjectSummaryViewModel}">
                <views:ProjectSummaryControl />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:NotesViewModel}">
                <views:NotesControl />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:SessionsViewModel}">
                <views:SessionsControl />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>